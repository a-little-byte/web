{
	"name": "@alittlebyte/api",
	"type": "module",
	"prisma": {
		"seed": "bun run prisma/seed.ts"
	},
	"scripts": {
		"postinstall": "prisma generate",
		"db:migrate": "bun -b prisma migrate dev",
		"db:seed": "bun -b prisma seed",
		"dev": "bun run --watch src/index.ts",
		"dev:email": "email dev",
		"generate": "bun -b @better-auth/cli generate",
		"lint": "eslint src/** && tsc",
		"lint:fix": "eslint src/** --fix && tsc"
	},
	"dependencies": {
		"@better-auth/cli": "0.5.2-beta.18",
		"@faker-js/faker": "^9.0.3",
		"@hono/zod-validator": "^0.4.1",
		"@prisma/client": "^5.20.1",
		"@prisma/engines": "^5.21.1",
		"@react-email/components": "0.0.25",
		"better-auth": "0.5.2-beta.10",
		"dotenv": "^16.4.5",
		"hono": "^4.6.3",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@alittlebyte/eslint-configs": "workspace:*",
		"@alittlebyte/typescript-configs": "workspace:*",
		"@types/node": "^20.11.17",
		"eslint": "^9.11.1",
		"prisma": "^5.20.1",
		"react-email": "3.0.1",
		"tsx": "^4.7.1",
		"typescript": "^5.5.3"
	}
}
