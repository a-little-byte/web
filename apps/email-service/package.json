{
  "name": "@alittlebyte/email-service",
  "version": "1.0.0",
  "scripts": {
    "dev": "run-p dev:*",
    "dev:copy": "bun -b nodemon -e proto --exec \"bun run\" ./copy.ts",
    "dev:server": "go run main.go",
    "build": "make  && (test -f ./server && ./server || ./server.exe)",
    "clean": "make clean"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "npm-run-all": "^4.1.5"
  }
}